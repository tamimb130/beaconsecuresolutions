# Beacon Secure — Apache / Hostinger config
ErrorDocument 404 /404.html

# Force HTTPS (uncomment once your SSL is active in Hostinger)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Optional: serve pages without the .html extension
# RewriteEngine On
# RewriteCond %{REQUEST_FILENAME}.html -f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule ^([^.]+)$ $1.html [L]

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml application/xml
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>
